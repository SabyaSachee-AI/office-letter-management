# Primary: PostgreSQL (Docker: docker compose up -d). Plain postgresql:// is normalized to postgresql+psycopg2://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/letter_management

# Optional local SQLite (schema via create_all on app startup; use Alembic only for PostgreSQL)
# DATABASE_URL=sqlite:///./office_letters.db

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_LEEWAY_SECONDS=30

# Use production only with a strong JWT_SECRET_KEY (≥32 random bytes recommended)
APP_ENV=development
LOG_LEVEL=INFO

# Upload caps (bytes); defaults 20971520 (20 MiB)
# MAX_LETTER_UPLOAD_BYTES=20971520
# MAX_SOLUTION_UPLOAD_BYTES=20971520
