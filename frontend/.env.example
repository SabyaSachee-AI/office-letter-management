# --- Recommended local dev (same-origin API via Next.js rewrite) ---
# Server-side: where FastAPI listens. Restart `npm run dev` after changes.
API_PROXY_TARGET=http://127.0.0.1:8000
# Do NOT set NEXT_PUBLIC_API_URL (or leave empty) so the browser uses /api/v1 on the same host as Next.js.

# --- Optional: call API directly from the browser (requires CORS on backend for your UI origin) ---
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
